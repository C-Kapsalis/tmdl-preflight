/// Standard date table, generated as a calculated table.
table Calendar
	lineageTag: calendar-table-tag-TODO

	column Date
		dataType: dateTime
		isKey
		formatString: Long Date
		lineageTag: 8033f304-f384-45c6-9be7-e2f304152637
		summarizeBy: none
		sourceColumn: [Date]

	partition Calendar = calculated
		mode: import
		source = CALENDAR(DATE(2024, 1, 1), DATE(2026, 12, 31))
