model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Sales","Products","Stores"]

ref table Calendar
ref table Products
ref table Stores
ref table Sales
ref table 'Sales Measures'
ref table 'Metric Selector'
